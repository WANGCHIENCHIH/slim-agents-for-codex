{
  "name": "slim-agents-for-codex",
  "version": "0.1.5",
  "description": "Deterministic oh-my-opencode-slim agent presets for Codex",
  "private": true,
  "type": "module",
  "author": "WANGCHIENCHIH",
  "keywords": ["codex", "agents", "toml", "presets", "cli"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WANGCHIENCHIH/slim-agents-for-codex.git"
  },
  "homepage": "https://github.com/WANGCHIENCHIH/slim-agents-for-codex#readme",
  "bugs": {
    "url": "https://github.com/WANGCHIENCHIH/slim-agents-for-codex/issues"
  },
  "bin": { "slim-agents-codex": "dist/cli.js" },
